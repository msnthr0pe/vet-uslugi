<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/textView11"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="36dp"
        android:layout_marginTop="180dp"
        android:text="Добавление\nживотного"
        android:textColor="@color/blue"
        android:textSize="40dp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/addAnimalForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@+id/textView11"
        tools:layout_editor_absoluteX="0dp">

        <EditText
            android:id="@+id/etAnimalName"
            android:layout_width="334dp"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:hint="Кличка"
            android:inputType="text" />

        <EditText
            android:id="@+id/etAnimalBreed"
            android:layout_width="334dp"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:hint="Порода"
            android:inputType="text" />

        <EditText
            android:id="@+id/etAnimalAge"
            android:layout_width="334dp"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:hint="Возраст"
            android:inputType="text" />

        <EditText
            android:id="@+id/etAnimalDescription"
            android:layout_width="334dp"
            android:layout_height="95dp"
            android:layout_marginTop="12dp"
            android:gravity="start"
            android:hint="Описание"
            android:inputType="textMultiLine" />

        <Button
            android:id="@+id/btnAddAnimal"
            android:layout_width="334dp"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:text="Добавить животное" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@android:color/transparent"
        android:indeterminate="true"
        android:indeterminateTint="@color/blue"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5" />

</androidx.constraintlayout.widget.ConstraintLayout>